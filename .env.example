# Polymarket 套利监控配置

# ==================== 基础配置 ====================

# 最小套利空间（百分比）
# 当 YES + NO < (100 - MIN_ARBITRAGE_PERCENT)% 时触发通知
# 建议值：0.5 - 2.0
MIN_ARBITRAGE_PERCENT=1.0

# 检查间隔（秒）
# 建议值：30-60（太频繁可能被限流）
CHECK_INTERVAL=30

# 最小流动性（美元）
# 低于此流动性的市场将被忽略
MIN_LIQUIDITY=5000

# 最大检查市场数
# Polymarket API 限制，建议不超过 200
MAX_EVENTS=200

# 市场标签过滤（可选）
# 多个标签用逗号分隔，如：sports,politics,crypto
# 留空表示监控所有市场
MARKET_TAGS=

# ==================== 通知配置 ====================

# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID（从 @userinfobot 获取）
TELEGRAM_CHAT_ID=

# Discord Webhook URL
DISCORD_WEBHOOK_URL=

# ==================== 高级配置 ====================

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# 数据保留天数
DATA_RETENTION_DAYS=30
